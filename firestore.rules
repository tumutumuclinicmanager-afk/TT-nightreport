rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'tumutumuclinicmanager@gmail.com' ||
        request.auth.token.email == 'wangechigodfrey77@gmail.com'
      );
    }

    // Rules for system/connection-test verification
    match /system/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Rules for Night Reports collection
    match /nightReports/{reportId} {
      allow read, write: if isAuthenticated();
    }

    // Rules for Whitelisted Emails
    match /whitelistedEmails/{emailId} {
      allow read, write: if isAuthenticated();
    }

    // Rules for Audit Logs
    match /auditLogs/{logId} {
      allow read, write: if isAuthenticated();
    }
  }
}
